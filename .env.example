# AWS credentials – leave empty to use IAM role / instance profile
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Set this to point at LocalStack when running locally
# AWS_ENDPOINT_URL=http://localhost:4566

# S3 destination
S3_BUCKET_NAME=tcc-etl-bucket
S3_PREFIX=data/

# Data source
SOURCE_URL=https://example.com/data.json

# Pipeline
BATCH_SIZE=10000
MAX_WORKERS=4

# Logging
LOG_LEVEL=INFO
